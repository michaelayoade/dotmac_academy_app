# App connection — uses app_user role, RLS-enforced
DATABASE_URL=postgresql+psycopg://app_user:app_user_pw@localhost:5432/dotmac_mt

# Online platform routes — uses platform_api role, no RLS bypass
PLATFORM_DATABASE_URL=postgresql+psycopg://platform_api:platform_api_pw@localhost:5432/dotmac_mt

# Migration / offline maintenance connection — uses app_admin role, bypasses RLS
MIGRATION_DATABASE_URL=postgresql+psycopg://app_admin:app_admin_pw@localhost:5432/dotmac_mt

# Tenant routing
PLATFORM_ROOT_DOMAIN=localhost  # e.g., "app.com" in prod; "localhost" in dev

# Required in production: hosts allowed by TrustedHostMiddleware
# In dev with subdomain.localhost, leave empty.
TRUSTED_HOSTS=

# JWT auth
JWT_SECRET=dev-insecure-change-me
SESSION_HASH_SECRET=dev-insecure-change-me
JWT_TTL_SECONDS=3600

# Browser/API guardrails
CSRF_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
TRUST_INBOUND_REQUEST_ID=false

ENVIRONMENT=dev
